rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own document tree.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{collection}/{doc=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
